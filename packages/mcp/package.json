{
  "name": "@quetra/mcp",
  "version": "0.2.3",
  "description": "QuetraAI MCP server — AI agent governance as MCP tools",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "quetra-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "homepage": "https://quetra.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/quetraai/quetra"
  },
  "keywords": [
    "quetra",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "claude"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@quetra/sdk": "^0.1.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
